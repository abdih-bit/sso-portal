# Environment Configuration
# Copy file ini menjadi .env dan sesuaikan nilainya

# ===========================
# SERVER CONFIGURATION
# ===========================
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Production:
# APP_URL=https://portal.hqmedan.com

# ===========================
# DATABASE CONFIGURATION
# ===========================
DATABASE_URL="postgresql://sso_user:your_password@localhost:5432/sso_portal?schema=public"

# ===========================
# JWT CONFIGURATION
# ===========================
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars_change_this_in_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_refresh_token_secret_change_this_in_production
JWT_REFRESH_EXPIRES_IN=7d

# ===========================
# SESSION CONFIGURATION
# ===========================
SESSION_SECRET=your_session_secret_key_change_this_in_production
SESSION_MAX_AGE=86400000

# ===========================
# SSO TOKEN CONFIGURATION
# ===========================
SSO_TOKEN_EXPIRES=300
# Token SSO berlaku 5 menit (300 detik)

# ===========================
# EMAIL CONFIGURATION (Optional)
# Untuk fitur reset password
# ===========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@hqmedan.com

# ===========================
# SECURITY
# ===========================
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
