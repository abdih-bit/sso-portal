# =====================================================
# SSO Portal - Environment Configuration Template
# =====================================================
# Instruksi:
# 1. Copy file ini menjadi .env
# 2. Sesuaikan setiap nilai dengan konfigurasi Anda
# 3. Jangan commit .env ke repository
# =====================================================

# =====================================================
# SERVER CONFIGURATION
# =====================================================
NODE_ENV=production
PORT=3000
APP_URL=https://portal.hqmedan.com

# =====================================================
# DATABASE - PostgreSQL
# =====================================================
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://sso_user:your-secure-password@localhost:5432/sso_portal

# =====================================================
# JWT (JSON Web Token)
# =====================================================
# Generate random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-min-32-characters-long-generated-randomly
JWT_EXPIRE=24h

# =====================================================
# SESSION CONFIGURATION
# =====================================================
SESSION_SECRET=your-session-secret-min-32-characters-long-generated-randomly
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=strict

# =====================================================
# CORS CONFIGURATION
# =====================================================
CORS_ORIGIN=https://portal.hqmedan.com
# Untuk multiple origins, gunakan: https://portal.hqmedan.com,https://app1.hqmedan.com,https://app2.hqmedan.com

# =====================================================
# EMAIL (SMTP Configuration)
# =====================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM=noreply@hqmedan.com
SMTP_FROM_NAME=SSO Portal

# Gmail Setup:
# 1. Enable "Less secure app access" or use App Passwords
# 2. Untuk App Password:
#    - Buka https://myaccount.google.com/apppasswords
#    - Pilih "Mail" dan "Windows Computer"
#    - Copy password yang digenerate

# =====================================================
# ADMIN ACCOUNT (First Time Setup)
# =====================================================
ADMIN_EMAIL=admin@hqmedan.com
ADMIN_PASSWORD=temporary-secure-password-CHANGE-THIS-IMMEDIATELY
ADMIN_USERNAME=admin

# =====================================================
# LOGGING
# =====================================================
LOG_LEVEL=info
LOG_FORMAT=combined

# =====================================================
# RATE LIMITING
# =====================================================
RATE_LIMIT_WINDOW_MS=15000
RATE_LIMIT_MAX_REQUESTS=100

# =====================================================
# PASSWORD RESET
# =====================================================
PASSWORD_RESET_TOKEN_EXPIRE=3600
PASSWORD_RESET_EMAIL_SUBJECT=Reset Password - SSO Portal

# =====================================================
# OPTIONAL: Third-party Integrations
# =====================================================
# LDAP / Active Directory (jika digunakan)
# LDAP_URL=ldap://your-ldap-server.com
# LDAP_BIND_DN=cn=admin,dc=hqmedan,dc=com
# LDAP_BIND_PASSWORD=password
# LDAP_SEARCH_BASE=dc=hqmedan,dc=com

# OAuth (untuk integrasi sosial media)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# =====================================================
# PRODUCTION SECURITY NOTES
# =====================================================
# ✓ Pastikan NODE_ENV=production
# ✓ Gunakan HTTPS untuk APP_URL
# ✓ Jangan expose .env file
# ✓ Generate secret keys yang kuat & unique
# ✓ Ganti ADMIN_PASSWORD setelah first login
# ✓ Setup firewall dengan ketat
# ✓ Regular backup database
# ✓ Monitor logs dan alerts
# ✓ Update dependencies secara berkala
